# ---- Editor ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ---- Node (dev tooling only) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ---- Logs ----
*.log
logs/

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local

# ---- Build output (none for this project, but just in case) ----
dist/
build/
out/

# ---- Temp ----
*.tmp
*.temp
